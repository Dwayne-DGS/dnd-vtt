# Dependencies — reinstalled on the server, never committed
node_modules/

# Local database files (your live game data lives on the server)
vtt.db
vtt.db-shm
vtt.db-wal

# Database backups (created on the server by backup.js)
backups/

# Uploaded images live on the server, not in git
public/uploads/

# Owner admin password — set on the server only, never committed
admin.key

# Hue helper's local config (bridge key, light choices) stays on that machine
hue-helper/config.json

# Anthropic API key for the AI assistant — server only, never committed
claude.key

# SSO / OAuth client secrets (Google, Discord) — server only, never committed
oauth.json

# Resend email API key — server only, never committed
resend.key

# The big self-contained installer is only needed for the no-GitHub method
install-on-server.sh

# OS noise
.DS_Store
image.key
